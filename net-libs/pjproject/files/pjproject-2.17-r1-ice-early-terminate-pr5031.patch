+static pj_bool_t wait_valid_pair_or_fail(pj_ice_sess *ice)
+{
+    /* Grace timer already running, keep waiting. */
+    if (ice->timer.id == TIMER_WAIT_VALID_PAIR)
+        return PJ_FALSE;
