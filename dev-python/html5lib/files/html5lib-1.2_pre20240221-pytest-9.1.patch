 html5lib/tests/test_encoding.py    |  4 ++--
 html5lib/tests/test_sanitizer.py   |  4 ++--
 html5lib/tests/test_serializer.py  | 12 +++++-------
 html5lib/tests/test_treewalkers.py |  4 ++--
 4 files changed, 11 insertions(+), 13 deletions(-)

