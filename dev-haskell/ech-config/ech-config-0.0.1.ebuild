EAPI=8

# ebuild generated by hackport 0.9.1.0

CABAL_FEATURES="lib profile haddock hoogle hscolour"
inherit haskell-cabal

DESCRIPTION="Config for TLS Encrypted Client Hello"
HOMEPAGE="https://hackage.haskell.org/package/ech-config"

LICENSE="BSD"
SLOT="0/${PV}"
KEYWORDS="~amd64"
IUSE="devel"

RDEPEND="dev-haskell/base16-bytestring:=[profile?]
	dev-haskell/network-byte-order:=[profile?]
	>=dev-lang/ghc-9.0.2:=
	devel? ( dev-haskell/base64-bytestring:=[profile?]
			dev-haskell/hpke:=[profile?] )
"
DEPEND="${RDEPEND}
	>=dev-haskell/cabal-3.4.1.0
"

src_configure() {
	haskell-cabal_src_configure \
		$(cabal_flag devel devel)
}
